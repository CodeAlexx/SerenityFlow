{
    "1": {
        "class_type": "LTXVLoader",
        "inputs": {
            "checkpoint_path": "ltx-2.3-22b-dev.safetensors",
            "gemma_path": "gemma-3-12b-it",
            "dtype": "bfloat16",
            "quantization": "auto",
            "backend": "legacy_stagehand"
        },
        "_meta": {"title": "Load LTX 2.3 Dev"}
    },
    "2": {
        "class_type": "LTXVSampler",
        "inputs": {
            "ltxv_model": ["1", 0],
            "prompt": "A cinematic dolly shot through a foggy forest at sunrise, dew on leaves, subtle wind in the canopy",
            "negative_prompt": "worst quality, inconsistent motion, blurry, jittery, distorted",
            "width": 768,
            "height": 512,
            "num_frames": 97,
            "steps": 25,
            "cfg": 3.0,
            "seed": 42,
            "frame_rate": 24,
            "stg_scale": 1.0,
            "mode": "dev"
        },
        "_meta": {"title": "Sample Video"}
    },
    "3": {
        "class_type": "SaveVideo",
        "inputs": {
            "video": ["2", 1],
            "filename_prefix": "ltx23_t2v",
            "fps": 24,
            "format": "mp4"
        },
        "_meta": {"title": "Save Video"}
    }
}
