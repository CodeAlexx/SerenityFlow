{
    "1": {
        "class_type": "LTXVLoader",
        "inputs": {
            "checkpoint_path": "ltx-2.3-22b-dev-fp8.safetensors",
            "gemma_path": "gemma-3-12b-it",
            "dtype": "bfloat16",
            "quantization": "auto",
            "backend": "legacy_stagehand"
        },
        "_meta": {"title": "Load LTX 2.3 Dev"}
    },
    "2": {
        "class_type": "LoadAudio",
        "inputs": {
            "audio": "input.mp3"
        },
        "_meta": {"title": "Load Audio"}
    },
    "3": {
        "class_type": "LTXVSampler",
        "inputs": {
            "ltxv_model": ["1", 0],
            "prompt": "A vibrant scene with dynamic motion perfectly synchronized to the audio rhythm",
            "negative_prompt": "worst quality, inconsistent motion, blurry, jittery, distorted",
            "width": 768,
            "height": 512,
            "num_frames": 97,
            "steps": 20,
            "cfg": 3.0,
            "seed": 42,
            "frame_rate": 24,
            "stg_scale": 1.0,
            "mode": "dev",
            "guide_strength": 1.0,
            "guide_frame_idx": 0,
            "audio": ["2", 0],
            "audio_start_time": 0.0,
            "audio_duration": 4.0
        },
        "_meta": {"title": "Sample Audio To Video"}
    },
    "4": {
        "class_type": "SaveVideo",
        "inputs": {
            "video": ["3", 1],
            "filename_prefix": "ltx23_a2v",
            "fps": 24,
            "format": "mp4"
        },
        "_meta": {"title": "Save Video"}
    },
    "5": {
        "class_type": "SaveAudioOpus",
        "inputs": {
            "audio": ["3", 2],
            "filename_prefix": "ltx23_a2v"
        },
        "_meta": {"title": "Save Audio"}
    }
}
