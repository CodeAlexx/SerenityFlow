{
    "1": {
        "class_type": "UNETLoader",
        "inputs": {
            "unet_name": "wan2.2_i2v_high_noise_14b_fp16.safetensors",
            "weight_dtype": "default"
        },
        "_meta": {"title": "Load WAN 2.2 I2V"}
    },
    "2": {
        "class_type": "CLIPLoader",
        "inputs": {
            "clip_name": "umt5_xxl_fp8_e4m3fn_scaled.safetensors",
            "type": "wan",
            "device": "default"
        },
        "_meta": {"title": "Load Text Encoder"}
    },
    "3": {
        "class_type": "VAELoader",
        "inputs": {
            "vae_name": "wan_2.1_vae.safetensors"
        },
        "_meta": {"title": "Load VAE"}
    },
    "4": {
        "class_type": "CLIPVisionLoader",
        "inputs": {
            "clip_name": "clip_vision_h.safetensors"
        },
        "_meta": {"title": "Load CLIP Vision"}
    },
    "5": {
        "class_type": "ModelSamplingSD3",
        "inputs": {
            "model": ["1", 0],
            "shift": 5.0
        },
        "_meta": {"title": "Model Sampling"}
    },
    "6": {
        "class_type": "LoadImage",
        "inputs": {
            "image": "input.png"
        },
        "_meta": {"title": "Load Source Image"}
    },
    "7": {
        "class_type": "CLIPVisionEncode",
        "inputs": {
            "clip_vision": ["4", 0],
            "image": ["6", 0]
        },
        "_meta": {"title": "CLIP Vision Encode"}
    },
    "8": {
        "class_type": "CLIPTextEncode",
        "inputs": {
            "clip": ["2", 0],
            "text": "the camera slowly pans across the scene, gentle motion"
        },
        "_meta": {"title": "Positive Prompt"}
    },
    "9": {
        "class_type": "CLIPTextEncode",
        "inputs": {
            "clip": ["2", 0],
            "text": "low quality, blurry"
        },
        "_meta": {"title": "Negative Prompt"}
    },
    "10": {
        "class_type": "WanImageToVideo",
        "inputs": {
            "positive": ["8", 0],
            "vae": ["3", 0],
            "image": ["6", 0],
            "clip_vision_output": ["7", 0],
            "width": 832,
            "height": 480,
            "length": 81
        },
        "_meta": {"title": "Image to Video Conditioning"}
    },
    "11": {
        "class_type": "KSampler",
        "inputs": {
            "model": ["5", 0],
            "positive": ["10", 0],
            "negative": ["9", 0],
            "latent_image": ["10", 2],
            "seed": 42,
            "steps": 20,
            "cfg": 3.5,
            "sampler_name": "euler",
            "scheduler": "simple",
            "denoise": 1.0
        },
        "_meta": {"title": "KSampler"}
    },
    "12": {
        "class_type": "VAEDecode",
        "inputs": {
            "samples": ["11", 0],
            "vae": ["3", 0]
        },
        "_meta": {"title": "VAE Decode"}
    },
    "13": {
        "class_type": "SaveVideo",
        "inputs": {
            "images": ["12", 0],
            "filename_prefix": "wan22_i2v",
            "fps": 24
        },
        "_meta": {"title": "Save Video"}
    }
}
